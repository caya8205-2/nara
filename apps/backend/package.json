{
  "name": "@nara/backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env ../../node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "agent:smoke": "node --env-file-if-exists=../../.env ../../node_modules/tsx/dist/cli.mjs src/scripts/agent-smoke.ts",
    "agent:simulate": "node --env-file-if-exists=../../.env ../../node_modules/tsx/dist/cli.mjs src/scripts/agent-simulate.ts",
    "db:generate": "node --env-file-if-exists=../../.env ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file-if-exists=../../.env ../../node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file-if-exists=../../.env ../../node_modules/drizzle-kit/bin.cjs push"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "bullmq": "^5.7.0",
    "ioredis": "^5.3.0",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "drizzle-kit": "^0.21.0"
  }
}
